# Copia este archivo como .env y rellena los valores reales

# Django
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=tu-app.ondigitalocean.app,localhost

# Base de datos (Digital Ocean Managed PostgreSQL)
# Formato: postgres://usuario:contraseña@host:puerto/nombre_db?sslmode=require
DBURL=postgres://doadmin:CONTRASEÑA@host.db.ondigitalocean.com:25060/defaultdb?sslmode=require
SSLMODE=require

# Archivos (Digital Ocean Spaces)
USE_SPACES=True
SPACES_KEY=tu_spaces_access_key
SPACES_SECRET=tu_spaces_secret_key
SPACES_BUCKET=nombre-del-bucket
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_CDN_ENDPOINT=nombre-del-bucket.nyc3.cdn.digitaloceanspaces.com

# Correo (SendGrid)
EMAIL_HOST_PASSWORD=SG.tu_api_key_de_sendgrid
FROM_EMAIL=invetario@transporteskasu.com.mx

# CSRF (pon la URL exacta de tu app en DO)
CSRF_TRUSTED_ORIGINS=https://tu-app.ondigitalocean.app

# URL base del servidor — se usa para generar las URLs dentro de los QR
BASE_URL=https://tu-app.ondigitalocean.app
